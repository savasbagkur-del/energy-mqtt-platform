NODE_ENV=production
API_PORT=3000

# Kendi-yonettigimiz Postgres (app sunucusunda Docker'da): POSTGRES_HOST = compose servis adi 'postgres'.
# Harici RDS kullanacaksan buraya RDS endpoint'ini yaz ve 'postgres' servisini baslatma.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=communication
POSTGRES_USER=communication_app
POSTGRES_PASSWORD=change_me

# Broker adresi: bu, WORKER'in (backend) baglandigi adres. Tek-host kurulumda compose'daki EMQX
# servis adi (emqx) veya ayri broker adresi. CIHAZLARA ise her zaman SABIT bir ALAN ADI yazilir
# (asla ham IP!) -> mqtt.your-domain.com. DNS'i (Route53) Elastic IP/NLB'ye yonlendir; sunucu/IP
# degisse de cihaz adresi degismez. Cihaz ekranindaki "IP address or domain name" alanina bunu yaz.
MQTT_HOST=mqtt.your-domain.com
# Cihazlar duz 1883 yerine TLS icin 8883'e baglanmali (bkz. MQTT_TLS_PORT).
MQTT_PORT=8883
# Backend (worker + dashboard) kimligi. NOT: cihazlarin PAYLASIMLI kimligi BUNDAN AYRIDIR ve
# EMQX auth'ta ayri bir kullanici olarak tanimlanir (bkz. deploy/RUNBOOK.md Bolum 12). Filo modeli:
# tum cihazlar AYNI paylasimli cihaz kullanici/parolasini kullanir; cihaz ayrimi SERI NUMARASI
# uzerinden yapilir. Whitelist acikken sahte bir SN baglansa bile 'quarantined' olur (spoof korumasi).
MQTT_USERNAME=backend_worker
MQTT_PASSWORD=change_me
# Worker'in KENDI client kimligi (benzersiz olmali; cihazlardan ayri).
MQTT_CLIENT_ID=communication-worker-prod-01

# Paylasimli CIHAZ kimligi (filo modeli): TUM cihazlar bu kullanici/parolayi kullanir; cihaz ekranina
# bu yazilir. Backend bu kimlikleri kullanmaz (yukaridaki MQTT_USERNAME ile baglanir). EMQX auth
# kurulumunda bu kullanici da olusturulur: infra/emqx/setup-emqx-auth.mjs (bkz. deploy/RUNBOOK.md B.12).
DEVICE_MQTT_USERNAME=fleet_device
DEVICE_MQTT_PASSWORD=change_me
# Faz 0: at-least-once teslim + kalici oturum. clientId instance basina BENZERSIZ olmali.
MQTT_QOS=1
MQTT_CLEAN_SESSION=false
# TLS ile broker'a baglan (mqtts://). Uretimde 8883 + TLS kullan -> true.
MQTT_TLS=true
# Broker'in TLS sertifikasini dogrula. Gercek (Let's Encrypt) sertifikada true birak. Kurulum
# sirasinda broker self-signed sertifika kullaniyorsa GECICI olarak false yap, gercek cert'ten sonra true.
MQTT_TLS_REJECT_UNAUTHORIZED=true
# Yapisal log esigi: debug | info | warn | error (mesaj-basina firehose loglari 'debug' seviyesinde)
LOG_LEVEL=info
SIMULATOR_MODE=false

# API kimlik dogrulama: tum API isteklerinde "Authorization: Bearer <token>" zorunlu olur
# (/health, /ready, /metrics haric). Bos birakirsan auth DEVRE DISI kalir (acik API) - uretimde
# MUTLAKA guclu bir deger ver. Uretmek icin: openssl rand -hex 32
API_AUTH_TOKEN=change_me_to_a_long_random_secret

# Cihaz whitelist: true ise sadece onceden kayitli sayaclar yonetilir; bilinmeyen SN'ler
# baglandiklarinda 'quarantined' (karantina) olarak kaydedilir (panelde gorunur ama komut
# gonderilemez). false = eski otomatik kayit davranisi.
DEVICE_WHITELIST_ENABLED=false

# Faz 1: dayanikli irade (desired-state) reconciler
# Reconciler ana anahtari (kapatmak icin false).
RECONCILE_ENABLED=true
# Reconciler degerlendirme periyodu (ms). Olcekte 5000-10000 onerilir.
RECONCILE_INTERVAL_MS=5000
# Bu sure icinde telemetri/presence gelmemisse cihaz offline sayilir (saniye). ~2x telemetri dongusu.
DEVICE_ONLINE_TTL_SEC=600

# Faz 2: yatay olcekleme. Bos = tekil worker (exclusive abonelik).
# Birden fazla worker instance calistiracaksan ayni grup adini ver (EMQX shared subscription ile
# inbound trafik instance'lar arasinda dengelenir). Komut/irade claim'leri DB'de atomik oldugu icin
# ayni cihaz/komut iki instance'ta islenmez. Her instance'in MQTT_CLIENT_ID'si BENZERSIZ olmali.
MQTT_SHARED_GROUP=workers

# Faz 2b: olcekleme ayar dugmeleri (varsayilanlar makul; yuksek yukte artir).
# Worker basina maksimum Postgres baglantisi (inbound fan-out + publish + reconcile + sweep icin).
PG_POOL_MAX=20
# Ayni anda islenen maks inbound MQTT mesaji; fazlasi bellekte siraya alinir (burst koruma).
MQTT_INBOUND_CONCURRENCY=16
# Publish dongusu basina (worker basina) claim/publish edilen maks komut.
PUBLISH_BATCH_SIZE=50

EMQX_DASHBOARD_PORT=18083
# MQTT over TLS port (devices connect here in production). EMQX ships a self-signed cert;
# replace it with a real one for production (see deploy/RUNBOOK.md "EMQX guvenligi").
MQTT_TLS_PORT=8883

# TLS reverse proxy (nginx, --profile tls). Put fullchain.pem + privkey.pem in infra/nginx/certs/.
HTTP_PORT=80
HTTPS_PORT=443

# Worker HTTP health/readiness/metrics port (orchestrator probes + Prometheus scrape).
# Endpoints: GET /health (liveness), /ready (db+mqtt+loop), /metrics (Prometheus).
WORKER_HEALTH_PORT=9100
# Worker /ready reports not_ready if the publish loop hasn't run within this many seconds.
WORKER_READY_MAX_LOOP_AGE_SEC=30

# Faz 3: fault/alarm bildirimleri. Genel webhook (POST JSON). Bos = devre disi (yalnizca log).
# Payload: { source, type, severity, message, sn, fields, timestamp }.
ALERT_WEBHOOK_URL=
# Ayni alarm anahtari (type:sn) icin minimum gonderim araligi (sn) - tekrar selini onler.
ALERT_MIN_INTERVAL_SEC=300
# Webhook POST zaman asimi (ms); worker yavas webhook'ta asla bloke olmaz.
ALERT_WEBHOOK_TIMEOUT_MS=5000

# Izleme yigini (Prometheus + Grafana, --profile monitoring). Prometheus, compose aginda
# api:3000/metrics ve mqtt-worker:9100/metrics uclarini scrape eder; alarm kurallari
# infra/prometheus/alerts.yml icinde. Grafana datasource + dashboard otomatik provision edilir.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
# Uretimde MUTLAKA degistir.
GRAFANA_ADMIN_PASSWORD=change_me
# Alertmanager: Prometheus alarmlarini webhook/Slack/e-postaya yonlendirir. Hedef kanali
# infra/alertmanager/alertmanager.yml icinde tanimlanir (Alertmanager env ikamesi yapmaz).
ALERTMANAGER_PORT=9093
