NODE_ENV=production
API_PORT=3000

POSTGRES_HOST=your-rds-endpoint.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=communication
POSTGRES_USER=communication_app
POSTGRES_PASSWORD=change_me

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=change_me
MQTT_CLIENT_ID=communication-worker-prod-01
# Faz 0: at-least-once teslim + kalici oturum. clientId instance basina BENZERSIZ olmali.
MQTT_QOS=1
MQTT_CLEAN_SESSION=false
# Yapisal log esigi: debug | info | warn | error (mesaj-basina firehose loglari 'debug' seviyesinde)
LOG_LEVEL=info
SIMULATOR_MODE=false

# Faz 1: dayanikli irade (desired-state) reconciler
# Reconciler ana anahtari (kapatmak icin false).
RECONCILE_ENABLED=true
# Reconciler degerlendirme periyodu (ms). Olcekte 5000-10000 onerilir.
RECONCILE_INTERVAL_MS=5000
# Bu sure icinde telemetri/presence gelmemisse cihaz offline sayilir (saniye). ~2x telemetri dongusu.
DEVICE_ONLINE_TTL_SEC=600

# Faz 2: yatay olcekleme. Bos = tekil worker (exclusive abonelik).
# Birden fazla worker instance calistiracaksan ayni grup adini ver (EMQX shared subscription ile
# inbound trafik instance'lar arasinda dengelenir). Komut/irade claim'leri DB'de atomik oldugu icin
# ayni cihaz/komut iki instance'ta islenmez. Her instance'in MQTT_CLIENT_ID'si BENZERSIZ olmali.
MQTT_SHARED_GROUP=workers

# Faz 2b: olcekleme ayar dugmeleri (varsayilanlar makul; yuksek yukte artir).
# Worker basina maksimum Postgres baglantisi (inbound fan-out + publish + reconcile + sweep icin).
PG_POOL_MAX=20
# Ayni anda islenen maks inbound MQTT mesaji; fazlasi bellekte siraya alinir (burst koruma).
MQTT_INBOUND_CONCURRENCY=16
# Publish dongusu basina (worker basina) claim/publish edilen maks komut.
PUBLISH_BATCH_SIZE=50

EMQX_DASHBOARD_PORT=18083

# Worker HTTP health/readiness/metrics port (orchestrator probes + Prometheus scrape).
# Endpoints: GET /health (liveness), /ready (db+mqtt+loop), /metrics (Prometheus).
WORKER_HEALTH_PORT=9100
# Worker /ready reports not_ready if the publish loop hasn't run within this many seconds.
WORKER_READY_MAX_LOOP_AGE_SEC=30
