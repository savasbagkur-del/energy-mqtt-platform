{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["energy-mqtt"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Energy MQTT Platform — Overview",
  "uid": "energy-mqtt-overview",
  "panels": [
    {
      "type": "stat",
      "title": "API up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [ { "refId": "A", "expr": "max(api_up)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat",
      "title": "Worker up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [ { "refId": "A", "expr": "max(worker_up)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat",
      "title": "MQTT connected",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NO", "color": "red" }, "1": { "text": "YES", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [ { "refId": "A", "expr": "max(worker_mqtt_connected)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat",
      "title": "DB up (api & worker)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [ { "refId": "A", "expr": "min(min(api_db_up), min(worker_db_up))", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries",
      "title": "Inbound MQTT queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "worker_inbound_queue_depth", "legendFormat": "queue depth", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "worker_inbound_active", "legendFormat": "active handlers", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Loop freshness (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "worker_last_publish_loop_age_seconds", "legendFormat": "publish loop age", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "worker_last_reconcile_loop_age_seconds", "legendFormat": "reconcile loop age", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Command verify outcomes (5m increase)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "increase(worker_command_verify_success_total[5m])", "legendFormat": "verify success", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "increase(worker_command_verify_fail_total[5m])", "legendFormat": "verify fail", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "increase(worker_command_late_confirmation_total[5m])", "legendFormat": "late confirmation", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Command ACK delivery (5m increase)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "increase(worker_command_ack_inbound_accepted_total[5m])", "legendFormat": "ack accepted", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "increase(worker_command_ack_timeout_retry_total[5m])", "legendFormat": "ack timeout (retry)", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "increase(worker_command_ack_timeout_delivery_total[5m])", "legendFormat": "ack timeout (final)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Fault alerts (15m increase)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "increase(worker_alerts_sent_total[15m])", "legendFormat": "sent", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "increase(worker_alerts_failed_total[15m])", "legendFormat": "failed", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "increase(worker_alerts_throttled_total[15m])", "legendFormat": "throttled", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "API memory (RSS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "expr": "api_process_resident_memory_bytes", "legendFormat": "api rss", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
