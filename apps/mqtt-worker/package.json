{
  "name": "mqtt-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "publish:test:login": "tsx src/publish-test.ts login",
    "publish:test:update": "tsx src/publish-test.ts update",
    "publish:test:operate": "tsx src/publish-test.ts operate",
    "publish:test:ack-listener": "node -e \"console.warn('Deprecated: use SIMULATOR_MODE=true with pnpm --filter mqtt-worker dev')\"",
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/command-lifecycle.scenario.test.ts src/reconciler.test.ts src/device-cadence.test.ts"
  },
  "dependencies": {
    "@communication/contracts": "workspace:*",
    "@communication/core": "workspace:*",
    "@communication/db": "workspace:*",
    "@communication/mqtt": "workspace:*",
    "mqtt": "^5.10.4"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
