# App
NODE_ENV=development
API_PORT=3000

# Postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=communication
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MQTT / EMQX
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=public
MQTT_CLIENT_ID=communication-worker
SIMULATOR_MODE=false
# Command outbound MQTT topic: indicate_server (default) or sys_server (protocol experiment)
COMMAND_TOPIC_MODE=indicate_server
# ACK wait window (seconds) before retry; field tuning
COMMAND_ACK_TIMEOUT_SEC=20
# Minimum delay (seconds) after timeout before republish (floors quick_retry 0s)
COMMAND_ACK_RETRY_MIN_DELAY_SEC=5
COMMAND_VERIFY_TIMEOUT_SEC=420
# Seconds after delivery_timeout during which telemetry can still close switch as late-confirmed (fallback if profile omits late_confirmation_window_sec)
COMMAND_LATE_CONFIRMATION_WINDOW_SEC=3600
EMQX_DASHBOARD_PORT=18083
EMQX_WS_PORT=8083
# API auth: require "Authorization: Bearer <token>" on all routes except /health,/ready,/metrics.
# Empty = auth disabled (dev). Generate: openssl rand -hex 32
API_AUTH_TOKEN=
# Device whitelist: true => unknown SNs are quarantined (not managed); pre-register to manage.
DEVICE_WHITELIST_ENABLED=false
